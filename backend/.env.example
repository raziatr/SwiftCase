# ── Server ──
NODE_ENV=development
PORT=4000
# CORS: origin yang diizinkan (mis. http://localhost:8123 atau * untuk semua)
CORS_ORIGIN=*

# ── Auth / JWT ──
# WAJIB diganti di produksi dengan string acak panjang
JWT_SECRET=ganti_dengan_secret_acak_panjang
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=10

# ── Database ──
# Path file SQLite (default: ./data/swiftcase.db)
# DB_FILE=./data/swiftcase.db

# ── Admin seed (dibuat saat DB kosong) ──
ADMIN_NAME=Administrator
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Business rules ──
LOW_STOCK_THRESHOLD=5
ORDERS_PER_PAGE=10

# ── Rate limiting ──
RATE_WINDOW_MS=900000     # 15 menit
RATE_MAX=300              # max request umum / window / IP
AUTH_RATE_WINDOW_MS=300000 # 5 menit
AUTH_RATE_MAX=5           # max percobaan login / window / IP+akun

# ── Xendit (QRIS) ──
# Kosongkan XENDIT_SECRET_KEY untuk MODE MOCK (tanpa panggilan API nyata).
# Isi dengan secret key dari dashboard Xendit untuk QRIS asli.
XENDIT_SECRET_KEY=
# Token verifikasi webhook (Settings > Webhooks di dashboard Xendit)
XENDIT_CALLBACK_TOKEN=
XENDIT_BASE_URL=https://api.xendit.co
