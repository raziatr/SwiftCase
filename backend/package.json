{
  "name": "swiftcase-backend",
  "version": "1.0.0",
  "description": "Backend API untuk SwiftCase POS — Express + SQLite, JWT auth, rate limiting, morgan logging, global error handler, SSE realtime, dan integrasi pembayaran QRIS Xendit.",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/db/seed.js",
    "backup": "node src/services/backupService.js",
    "gen-cert": "node scripts/gen-cert.js"
  },
  "keywords": [
    "pos",
    "express",
    "sqlite",
    "xendit",
    "qris"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}